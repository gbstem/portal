# ==============================================================================
# FIREBASE ADMIN SDK CONFIGURATION
# ==============================================================================
# Log in to your Firebase Console at: https://console.firebase.google.com/
# Navigate to Project settings -> Service accounts, select the Firebase Admin SDK,
# and click "Generate new private key". The generated JSON file contains these values.
# Note: For FIREBASE_PRIVATE_KEY, copy the exact private key block including \n characters.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@demo-gbstem.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=demo-gbstem

# ==============================================================================
# FIREBASE PUBLIC WEB APP CONFIGURATION
# ==============================================================================
# Log in to your Firebase Console at: https://console.firebase.google.com/
# Navigate to Project settings -> General. Under "Your apps", select your Web App
# to view the Firebase SDK snippet configuration parameters.
PUBLIC_FIREBASE_API_KEY=AIzaSyA1234567890abcdefghijklmnopqrst
PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890
PUBLIC_FIREBASE_AUTH_DOMAIN=demo-gbstem.firebaseapp.com
PUBLIC_FIREBASE_MEASUREMENT_ID=G-12345ABCDE
PUBLIC_FIREBASE_MESSAGE_SENDER_ID=1234567890
PUBLIC_FIREBASE_PROJECT_ID=demo-gbstem
PUBLIC_FIREBASE_STORAGE_BUCKET=demo-gbstem.appspot.com

# ==============================================================================
# SENDGRID CONFIGURATION
# ==============================================================================
# Log in to your SendGrid account at: https://sendgrid.com/
# Navigate to Settings -> API Keys and create a new API Key with appropriate access.
SENDGRID_API_TOKEN=SG.abcdefghijklmnopqrstuvwxyz.1234567890abcdefghijklmnopqrstuvwxyz

# ==============================================================================
# MICROSOFT OAUTH CONFIGURATION (ENTRA ID) FOR CREATING TEAMS MEETING LINKS
# ==============================================================================
# Log in to the Azure Portal / Microsoft Entra Admin Center at: https://portal.azure.com/
# Navigate to Microsoft Entra ID -> App registrations. Register your app or select one.
# - VITE_CLIENT_ID: Found under the "Overview" page as the Application (client) ID.
# - VITE_CLIENT_SECRET: Generated under "Certificates & secrets" -> "Client secrets".
# For local development and testing, this will just lead to the "Create meeting link"
# failing, but the rest of the UI will be fully functional.
VITE_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_CLIENT_SECRET=abc12~34567890abcdefghijklmnopqrstuvwx

# ==============================================================================
# FIREBASE EMULATOR CONFIGURATION (Uncomment to use local emulation)
# ==============================================================================
# FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
# FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
# STORAGE_EMULATOR_HOST="127.0.0.1:9199"
