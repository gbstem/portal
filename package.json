{
  "name": "portal",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "start": "npm run dev -- --open",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format:check": "prettier . --check .",
    "format": "prettier --write --plugin prettier-plugin-svelte --plugin prettier-plugin-tailwindcss .",
    "test": "jest",
    "cypress:run": "start-server-and-test start http://localhost:3000 cypress",
    "cypress": "cypress run",
    "deploy": "npm run build && firebase deploy",
    "emulators": "firebase emulators:start --log-verbosity=quiet",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-feather-icons": "^4.2.0",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  },
  "type": "module",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "cypress": "^15.17.0",
    "cypress-terminal-report": "^7.3.3",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "formsnap": "^2.0.1",
    "lodash-es": "^4.18.1",
    "nanoid": "^5.1.11",
    "node-fetch": "^3.3.2",
    "nprogress": "^0.2.0",
    "portal": "file:",
    "qrious": "^4.0.2",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  }
}
