    "file-saver": "^2.0.5",
    "firebase": "^10.14.1",
    "firebase-admin": "^11.11.1",
    "lodash-es": "^4.18.1",
    "nanoid": "^5.1.11",
    "node-fetch": "^3.3.2",
    "nprogress": "^0.2.0",
    "pdf-parse": "^1.1.4",
    "pdfjs-dist": "^3.11.174",
    "portal": "file:",
    "postmark": "^4.0.7",
    "qrious": "^4.0.2",
    "react-pdf": "^7.7.3",
    "svelte-pdf": "^1.0.28",
    "tailwind-merge": "^1.14.0"
  }
